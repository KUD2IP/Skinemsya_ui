# --- Режим по умолчанию (рекомендуется): прокси через Vite ---
# Не задавай VITE_API_BASE_URL — фронт будет ходить на свой origin (/api/v1),
# а Vite проксирует /api на бэкенд ниже. Тогда нужен только ОДИН туннель (для фронта),
# и CORS на бэке не требуется.
VITE_API_PROXY_TARGET=http://localhost:8080

# --- Альтернатива: прямое обращение к API (нужен CORS на бэке) ---
# Раскомментируй и укажи полный адрес API, если не хочешь прокси.
# Тогда origin фронта нужно добавить в skinemsya.cors.allowed-origin-patterns на бэке.
# VITE_API_BASE_URL=https://your-backend.ngrok-free.dev/api/v1
